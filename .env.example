# Шаблон переменных окружения.
# Скопируй этот файл в .env и заполни своими значениями:
#   cp .env.example .env

# Токен Telegram-бота (получить у @BotFather → /newbot)
BOT_TOKEN=your_bot_token_here

# Supabase (взять в: Dashboard → Settings → API)
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXX

# ID мастера в таблице masters
MASTER_ID=1

# Секрет для Cron-эндпоинта (придумать любую строку)
CRON_SECRET=

# DEV_MODE=true — разрешить запросы без Telegram initData (только локально!)
# DEV_MODE=true
